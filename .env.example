# Environment Variables
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# Email Configuration (for Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
